#include <stdio.h>

int main() {
    int vehicleType, distance;
    int fare;
    scanf("%d %d", &vehicleType, &distance);
    switch(vehicleType) {
        case 1:
            fare = distance * 10;
            break;
        case 2:
            fare = distance * 15;
            break;
        case 3:
            fare = distance * 20;
            break;
        default:
            printf("Invalid Vehicle Type");
            return 0;
    }
    printf("Taxi Fare ₹%d", fare);
    return 0;
}
